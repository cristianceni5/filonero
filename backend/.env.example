NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/filonero
DATABASE_SSL=false

JWT_ACCESS_SECRET=replace_with_at_least_32_chars_secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30
MAGIC_LINK_TTL_MINUTES=15

APP_BASE_URL=https://filonero.cenidev.com
API_BASE_URL=https://filonero.cenidev.com/api

RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@filonero.cenidev.com

CORS_ALLOWED_ORIGINS=*

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REGISTER=10
RATE_LIMIT_MAX_LOGIN=20
RATE_LIMIT_MAX_MAGIC_LINK=10

LOG_REQUESTS=true
